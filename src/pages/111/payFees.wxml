<!--pages/payFees/payFees.wxml-->
<layout 
  id="layout" 
  pb="0" 
  bg-color="#fff" 
>
  <!-- show-bg-top
  bg-top-height="calc({{ wallet_balance_wrap_height }} + {{ nav_style.total_height }})"
  bg-top="url(/assets/images/tianhao/fee_top_bg.jpg) no-repeat top 70% center / 100% auto" -->
  <pic class="page-top-bg" src="/assets/images/tianhao/fee_top_bg.jpg"/>
  <nav-top-bar 
    title="预缴物业费"
    bg-color="transparent"
    is-show-back
    is-show-home
  >
  </nav-top-bar>

  <view class="wallet-balance-wrap">
    <view class="wallet-balance">钱包余额(元)</view>
    <view class="wallet-balance-amount">{{total_balance}}</view>
  </view>

  <view class="fee-wrap">  
    <view class="page-container">
      
      <view class="fee-item-title">选择缴费的金额(元)</view>
          
      <!-- 添加金额列表 -->
      <view class="amount-list">
        <view 
          class="amount-item {{selected_amount === item.value ? 'active' : ''}}" 
          wx:for="{{amount_list}}" 
          wx:key="value"
          data-id="{{item.id}}"
          data-amount="{{item.value}}"
          bindtap="handleSelectAmount"
        >
          ¥{{item.value}}
          <pic class="icon-choosed" w="50rpx" src="/assets/images/tianhao/icon_choosed.svg"/>
        </view>
      </view>

      <!-- 自定义金额输入框 -->
      <view class="custom-amount">
        <view class="custom-amount-title">自定义金额</view>
        <view 
          class="input-wrap {{ is_select_custom_amount ? 'on' : '' }}"
          bind:tap="handleSelectCustomAmount"
        >
          <text class="currency">金额</text>
          <input 
            type="digit"
            class="amount-input"
            value="{{custom_amount}}"
            placeholder="请输入金额"
            maxlength="6"
            data-field="custom_amount"
            bindinput="$inputValue"
          />
        </view>
      </view>

    </view>
  </view>

  <!-- 缴费记录 -->
  <view class="payment-record" >
    <view bind:tap="$nav" data-url="/pages/index/payFees/payRecord/payRecord">充值记录</view>
    <view class="mx-30">|</view>
    <view bind:tap="$nav" data-url="/pages/mine/paymentRecord/paymentRecord">支付记录</view>
  </view>

  <bottom-bar 
    show-left="{{ false }}"
    right-width="100%"
    right-text="立即支付" 
    bind:click-right="handleShowPayComfirmPopup"
  >
  </bottom-bar>


</layout>


<bottom-popup 
  show="{{ is_show_comfirm_pay_popup }}" 
  max-height="auto"
  title="缴费信息"
  data-field="is_show_comfirm_pay_popup"
  custom-bottom
  bind:close="$toggleOff" 
>
  <view class="custom-amount">
    <view class="input-wrap">
      <text class="currency">金额</text>
      <view class="amount-input flex items-center text-bold color-danger">
        <view>¥</view>
        <view>{{custom_amount || selected_amount}}</view>
      </view>
      <view>元</view>
    </view>
  </view>
  
  

  
  <view class="flex mb-40 fz-26 my-30">
    <app-icon 
      wx:if="{{ !is_agree }}"
      icon="icon-weixuanzhong" 
      size="42rpx"
      color="#b2b2b2"
      bind:click="$changeValue"
      data-field="is_agree"
      data-value="{{ true }}"
    ></app-icon>
    <app-icon 
      wx:if="{{ is_agree }}"
      icon="icon-chenggong1" 
      size="42rpx"
      color="var(--primary-color)"
      bind:click="$changeValue"
      data-field="is_agree"
      data-value="{{ false }}"
    ></app-icon>
    <view class="ml-10 flex-1 color-999"
      bind:tap="$toggle"
      data-field="is_agree"
    >我已核实<text class="color-primary">收费人物业管理处、收费项目</text>的真实性，并阅读了
    <text bind:tap="$nav" data-url="/pages/login/agreement/agreement" class="color-primary">《服务协议》</text>，我同意支付费用。
    </view>
  </view>

  <view slot="bottom" class="pb-30 flex items-center justify-between">
    <!-- <view class="flex items-center">
      <view class="fz-30">合计</view>
      <view class="fz-30 ml-20 color-danger">¥ {{ custom_amount }}</view>
    </view> -->
    <btn w="690rpx" bind:click="handleConfirmPay">确认</btn>
  </view>
</bottom-popup>

<bottom-popup 
  show="{{ is_show_pay_popup }}" 
  max-height="auto"
  title="缴费信息"
  custom-bottom
  data-field="is_show_pay_popup"
  bind:close="$toggleOff" 
>
  <view class="fc flex-col pt-20">

    <pic w="268rpx" src="{{pay_qrcoder_url}}" longpress />
    <!-- <view class="my-30 color-666 hide-parent" >
      长按保存后扫码支付
    </view> -->
  </view>
  
  <!-- 支付引导步骤 -->
  <view class="pay-guide">
    <view class="guide-title">支付步骤</view>
    <view class="guide-steps">
      <view class="step-item" wx:for="{{paySteps}}" wx:key="index">
        <text class="step-number">{{index + 1}}.</text>
        <text class="step-text">{{item}}</text>
      </view>
    </view>
  </view>


  <view slot="bottom" class="py-30 flex gap-30">
    <view class="flex-1">
      <btn w="100%" type="normal" font-color="white" color="#07c160" border-width="0" bind:click="handleNavToScanPay">扫一扫</btn>
    </view>
    <view class="flex-1">
      <btn w="100%" bind:click="handleHavePaid">我已支付</btn>
    </view>
  </view>
</bottom-popup>
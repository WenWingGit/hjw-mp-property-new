/* pages/index/payFees/payFees.wxss */
.wallet-balance-wrap{
  padding: 40rpx 30rpx 100rpx;
  color: #fff;
}
.wallet-balance{
  font-size: 24rpx;
}
.wallet-balance-amount{
  margin-top: 15rpx;
  font-size: 48rpx;
  font-weight: bold;
}
.fee-wrap{
  z-index: 2;
  position: relative;
  margin-top: -30rpx;
  border-radius: 20rpx 20rpx 0 0;
  background-color: #fff;
  padding: 30rpx;
}

.fee-list {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.fee-item-title {
  font-size: 32rpx;
  font-weight: 500;
  margin-bottom: 30rpx;
}

.amount-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.amount-item {
  position: relative;
  width: calc(33.33% - 14rpx);
  height: 148rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f8f9fb;
  border-radius: 30rpx;
  box-sizing: border-box;
  font-size: 40rpx;
  border: 2px solid #f8f9fb;
  font-weight: bold;
}

.icon-choosed{
  position: absolute;
  right: 0;
  bottom: 0;
  opacity: 0;
  visibility: hidden;
}

.amount-item.active {
  border: 2px solid var(--primary-color);
}

.amount-item.active .icon-choosed{
  opacity: 1;
  visibility: visible;
}

.custom-amount {
  border-top: 1px solid #eee;
  padding-top: 30rpx;
}

.custom-amount-title {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.input-wrap {
  display: flex;
  align-items: center;
  background: #f8f9fb;
  border: 4rpx solid #f8f9fb;
  padding: 40rpx;
  border-radius: 20rpx;
}

.input-wrap.on{
  border-color: var(--primary-color);
}

.currency {
  font-size: 30rpx;
  margin-right: 20rpx;
  font-weight: bold;
}

.amount-input {
  flex: 1;
  font-size: 32rpx;
}

.payment-record{
  position: fixed;
  left: 0;
  bottom: 230rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  line-height: 1;
  width: 100%;
  color: #888;
  text-align: center;
}



.qrcode-image {
  width: 400rpx;
  height: 400rpx;
  margin-bottom: 20rpx;
}

.qrcode-tip {
  font-size: 26rpx;
  color: #999;
}

.save-btn {
  width: 80%;
  margin: 30rpx auto;
}

.pay-guide {
  margin: 40rpx 0 20rpx;
  padding: 30rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
}

.guide-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 20rpx;
  font-weight: bold;
}

.guide-steps {
  font-size: 26rpx;
  color: #666;
}

.step-item {
  display: flex;
  margin-bottom: 16rpx;
}

.step-number {
  margin-right: 10rpx;
  color: #333;
  font-weight: bold;
}

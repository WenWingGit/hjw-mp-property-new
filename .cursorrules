# 租车小程序的界面 - 智能代码提示增强配置
# Vue3 + uni-app + TypeScript 项目
优先使用简体字，是单语言项目
项目用rpx做单位
## 项目结构和导入路径
### 路径别名配置
- @/ 指向 src/
- @/components/ 指向 src/components/
- @/utils/ 指向 src/utils/
- @/hooks/ 指向 src/hooks/
- @/service/ 指向 src/service/
- @/types/ 指向 src/types/
- @/store/ 指向 src/store/

### 导入优先级规则
1. 优先推荐项目内已封装的功能
2. 推荐uni-app官方API
3. 推荐Vue3 Composition API
4. 推荐wot-design-uni组件库
5. 最后推荐第三方库

## 核心工具函数库 (src/utils/)
### 路由和URL处理
```typescript
// obj2Url - 对象转URL参数
obj2Url(obj: object, isEncode: boolean): string
// 使用示例：obj2Url({name: '张三', age: 25}, true)

// getUrlObj - 解析URL获取path和query
getUrlObj(url: string): {path: string, query: Record<string, string>}
// 使用示例：getUrlObj('/pages/login?redirect=%2Fpages%2Fhome')

// currRoute - 获取当前页面路由信息
currRoute(): {path: string, query: Record<string, string>}

// navToLogin - 跳转到登录页
navToLogin(): void

// navToHome - 跳转到首页  
navToHome(): void

// getIsTabbar - 判断当前是否为tabbar页面
getIsTabbar(): boolean

// getAllPages - 获取所有页面配置
getAllPages(key?: string): Array<{path: string, [key: string]: any}>

// getNeedLoginPages - 获取需要登录的页面路径
getNeedLoginPages(): string[]
```

### HTTP请求工具 (src/utils/http.ts)
```typescript
// 统一的HTTP请求封装，自动添加token和错误处理
import { http } from '@/utils/http'
// GET请求：http.get(url, params)
// POST请求：http.post(url, data)  
// PUT请求：http.put(url, data)
// DELETE请求：http.delete(url, params)
```

### 存储工具 (src/utils/storage.ts)
```typescript
// 本地存储封装，支持过期时间
import { setStorage, getStorage, removeStorage } from '@/utils/storage'
```

## 核心Hooks库 (src/hooks/)
### 文件上传相关
```typescript
// useUpload - 图片上传hook
import useUpload from '@/hooks/useUpload'
const { loading, error, data, run } = useUpload<string>(
  formData?: Record<string, any>,
  accept?: 'image' | 'video', 
  count?: number
)

// useUploadVideo - 视频上传hook  
import { useUploadVideo } from '@/hooks/useUpload'
const { loading, error, data, run } = useUploadVideo<string>(formData?, count?)

// useUploadFile - 文件上传hook
import useUploadFile from '@/hooks/useUploadFile'
const { loading, error, data, run } = useUploadFile<string>()
```

### 数据请求相关
```typescript
// useRequest - 请求封装hook
import useRequest from '@/hooks/useRequest'
const { loading, error, data, run } = useRequest(requestFn, options?)
```

### UI交互相关
```typescript
// useLockScroll - 锁定滚动
import useLockScroll from '@/hooks/useLockScroll'
const { lock, unlock } = useLockScroll()

// useExpandState - 展开/收起状态
import useExpandState from '@/hooks/useExpandState'
const { expanded, toggle, expand, collapse } = useExpandState(defaultValue?)

// useDomRect - 获取DOM元素尺寸信息
import useDomRect from '@/hooks/useDomRect'
const { rect, update } = useDomRect(selector)
```

### 业务逻辑相关
```typescript
// useSendCode - 发送验证码
import useSendCode from '@/hooks/useSendCode'
const { loading, countdown, canSend, sendCode } = useSendCode()

// useUserPermission - 用户权限
import useUserPermission from '@/hooks/useUserPermission'  
const { hasPermission, checkPermission } = useUserPermission()

// useStorage - 响应式存储
import useStorage from '@/hooks/useStorage'
const [value, setValue] = useStorage(key, defaultValue)
```


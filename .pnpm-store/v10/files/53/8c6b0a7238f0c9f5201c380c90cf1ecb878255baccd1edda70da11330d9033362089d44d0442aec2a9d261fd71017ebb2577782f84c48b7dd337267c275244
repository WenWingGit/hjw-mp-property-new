'use strict';

var version = "0.0.1";

class NumeralsConverter {
  array;
  constructor(array) {
    this.array = array;
  }
  getValueFromIndex(index) {
    const numberString = index.toString();
    let result = "";
    for (const num of numberString) {
      const str = this.array[+num];
      if (str) {
        result += str;
      }
    }
    return result;
  }
  getIndexFromValue(strList) {
    let result = "";
    for (const str of strList) {
      const index = this.array.indexOf(str);
      if (index > -1) {
        result += index;
      }
    }
    return result;
  }
}

const NUMBER_REGEX = /^[-+]?(?:\d+(?:\.\d*)?|\.\d+)$/;
function isValidNumber(num) {
  const numString = num.toString();
  return NUMBER_REGEX.test(numString);
}

const SCIENTIFIC_NOTATION_REGEX = /^[-+]?[0-9]+(\.[0-9]+)?[eE][-+]?[0-9]+$/;
function isScientificNotation(num) {
  const numString = num.toString();
  return SCIENTIFIC_NOTATION_REGEX.test(numString);
}

function scientificToNumber(num) {
  const numString = num.toString();
  if (isScientificNotation(numString)) {
    const sign = Math.sign(+numString);
    const unsignedIntegers = numString.replace(/^[+-]/, "");
    const zero = "0";
    const [base, exponent] = unsignedIntegers.toLowerCase().split("e");
    let unsignedExponent = Math.abs(+exponent);
    const [integerPart, fractionalPart = ""] = base.split(".");
    let result = "";
    if (exponent.startsWith("-")) {
      result = zero + "." + new Array(unsignedExponent).join(zero) + integerPart + fractionalPart;
    } else {
      if (fractionalPart) {
        unsignedExponent = unsignedExponent - fractionalPart.length;
      }
      result = integerPart + fractionalPart + new Array(unsignedExponent + 1).join(zero);
    }
    return sign === -1 ? `-${result}` : result;
  } else {
    return Number(numString).toString();
  }
}

function replaceCharacters(mode, str, searchString, remove) {
  if (mode === "start") {
    str = str.replace(new RegExp(`^${searchString}+`, "g"), remove ? "" : searchString);
  } else if (mode === "middle") {
    str = str.replace(new RegExp(`${searchString}+`, "g"), remove ? "" : searchString);
  } else if (mode === "end") {
    str = str.replace(new RegExp(`${searchString}+$`, "g"), remove ? "" : searchString);
  }
  return str;
}
function operateSequentCharacters(str, searchString, modes) {
  if (Array.isArray(modes)) {
    for (let i = 0; i < modes.length; i++) {
      const { mode, remove = true } = modes[i];
      str = replaceCharacters(mode, str, searchString, remove);
    }
  } else {
    const { mode, remove = true } = modes;
    str = replaceCharacters(mode, str, searchString, remove);
  }
  return str;
}

function parseRationalNumber(str) {
  if (typeof str !== "string") {
    throw new Error("Invalid input. Please provide a valid string.");
  }
  const result = {
    sign: "",
    integerPart: "",
    fractionalPart: ""
  };
  if (str.startsWith("-")) {
    result.sign = "-";
  } else {
    result.sign = "+";
  }
  const parts = str.split(".");
  const integerPart = parts[0].replace(/^[+-]/, "");
  const withoutLeadingZeroInteger = operateSequentCharacters(integerPart, "0", { mode: "start" });
  if (withoutLeadingZeroInteger.length) {
    result.integerPart = withoutLeadingZeroInteger;
  } else {
    result.integerPart = "0";
  }
  if (parts.length > 1) {
    result.fractionalPart = operateSequentCharacters(parts[1], "0", { mode: "end" });
  }
  if (result.integerPart + result.fractionalPart === "0") {
    result.sign = "+";
  }
  return result;
}


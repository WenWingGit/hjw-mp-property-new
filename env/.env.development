# 变量必须以 VITE_ 为前缀才能暴露给外部读取
NODE_ENV = 'development'
VITE_NODE_ENV = 'development'
# 是否去除console 和 debugger
VITE_DELETE_CONSOLE = false
# 是否开启sourcemap
VITE_SHOW_SOURCEMAP = true


# 开发环境
# VITE_SERVER_BASEURL = 'http://192.168.1.11:7319'
# 正式环境
VITE_SERVER_BASEURL = 'http://hjwwuye.think-will.net'

# 是否不需要登录
VITE_NOT_NEED_LOGIN = false

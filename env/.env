VITE_APP_TITLE = '汇景湾物业缴费'
VITE_APP_PORT = 9020

VITE_UNI_APPID = '__UNI__83107A7'
# 微信小程序appid
VITE_WX_APPID = 'wx13d653ecdc8d3968'

# h5部署网站的base，配置到 manifest.config.ts 里的 h5.router.base
VITE_APP_PUBLIC_BASE=/hjw-mp-property-new/

# 后端接口地址
VITE_SERVER_BASEURL = 'https://sys.yilianqc.com'

# 上传图片接口
VITE_UPLOAD_BASEURL = '/WxMinApi/WtlUpload/UploadImage'
# 上传文件接口
VITE_UPLOAD_FILE_BASEURL = '/WxMinApi/WtlUpload/UploadFile'

# 首页页面
VITE_APP_HOME_PAGE = '/pages/index/index'

# 登录页面
VITE_APP_LOGIN_PAGE = '/pages/login/wxLogin'

# h5是否需要配置代理
VITE_APP_PROXY=true
VITE_APP_PROXY_PREFIX = '/WxMinApi'

# 版本
VITE_APP_VERSION = 'v1.0.0'

# 内部版本号
VITE_APP_INNER_VERSION = '10000'

# 缓存版本
VITE_APP_CACHE_VERSION = 'v1_0_1'

# 能够上传文件类型
VITE_APP_UPLOAD_TYPE = '.pdf,.jpg,.png,.jpeg'

# 是否不需要登录浏览页面
VITE_NOT_NEED_LOGIN = false

# 是否为静态页面（是为给用户测试，没有对接功能）
VITE_IS_STATIC_PAGE = true

# （wot-design-uni下拉用的是label和value，这里填写一下后端返回的对应的label和value）
VITE_APP_WOT_LABEL_KEY = 'label'
VITE_APP_WOT_VALUE_KEY = 'value'

VITE_APP_LABEL_KEY = 'name'
VITE_APP_VALUE_KEY = 'id'
